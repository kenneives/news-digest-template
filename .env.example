# =============================================================================
# Claude API
# =============================================================================
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# =============================================================================
# Gmail SMTP Configuration
# =============================================================================
# To get an app password: Google Account > Security > 2-Step Verification > App passwords
GMAIL_ADDRESS=your_email@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password
RECIPIENT_EMAIL=recipient@example.com,another@example.com

# =============================================================================
# Logging
# =============================================================================
# LOG_FILE is the main log output path used by cron/Task Scheduler redirection.
# LOG_RETENTION_DAYS deletes rotated `digest.log.*` files older than this value.
LOG_FILE=digest.log
LOG_RETENTION_DAYS=30

# =============================================================================
# Digest Settings
# =============================================================================
MAX_ARTICLES_PER_SOURCE=20
# Claude model selection (fallback order: latest Sonnet -> Opus -> Haiku)
# USE_LATEST_MODELS=true auto-resolves the newest Sonnet/Opus/Haiku from the
# Models API each refresh. The model IDs hardcoded in news_digest.py are only a
# fallback for when that lookup fails — you don't maintain them. A 404 from any
# resolved model falls through to the next family, so a model retirement never
# fails the digest.
USE_LATEST_MODELS=true
# How often to re-check the Models API. 1 = re-resolve daily, so you always get
# the newest model and retired ones drop off within a day.
MODEL_REFRESH_DAYS=1
# Optional escape hatch: pin the PRIMARY model (fallbacks still apply). Uncomment
# to roll back if a newly released model ever produces worse digests.
# DIGEST_MODEL=claude-sonnet-4-6

# =============================================================================
# Optional: Remote sync of digest_history.json
# =============================================================================
# Best-effort scp of digest_history.json to another machine after each run —
# useful if a downstream consumer there reads the news/reddit signals. Leave
# DIGEST_SYNC_HOST blank to skip the sync entirely (the default).
DIGEST_SYNC_HOST=
DIGEST_SYNC_USER=user
DIGEST_SYNC_KEY=~/.ssh/your-key.pem
DIGEST_SYNC_PATH=/home/USER/news-digest/digest_history.json

# =============================================================================
# Podcast Audio Pipeline
# =============================================================================
# Local LLM via Ollama (default: localhost since everything runs on same machine)
LOCAL_LLM_URL=http://localhost:11434
# Model for podcast script generation. If not found locally, it will be
# auto-pulled from the Ollama registry.
# Timeouts scale with model size: 8b=5min, 14b=10min, 30b=15min.
LOCAL_LLM_MODEL=qwen3.5:9b

# Audio output directory — setting this enables the podcast pipeline.
# Use a path that exists and is writable, e.g. /path/to/news-digest/audio
AUDIO_OUTPUT_DIR=/path/to/news-digest/audio

# Audiobookshelf
AUDIOBOOKSHELF_URL=http://localhost:13378
AUDIOBOOKSHELF_API_KEY=
AUDIOBOOKSHELF_LIBRARY_ID=

# Optional intro/outro music
INTRO_MUSIC_PATH=
OUTRO_MUSIC_PATH=

# ElevenLabs TTS (optional — falls back to Edge-TTS if not set or on error)
ELEVENLABS_API_KEY=
# Voice IDs: pin specific voices, or leave blank to auto-rotate daily
ELEVENLABS_VOICE_ALEX=
ELEVENLABS_VOICE_SAM=
ELEVENLABS_MODEL=eleven_multilingual_v2

# Test mode (2-minute sample)
PODCAST_TEST_MODE=false
